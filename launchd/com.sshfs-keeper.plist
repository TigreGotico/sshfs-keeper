<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.sshfs-keeper</string>

  <key>ProgramArguments</key>
  <array>
    <!-- uv tool puts the binary here; adjust if you used pip install -->
    <string>/Users/YOUR_USERNAME/.local/bin/sshfs-keeper</string>
  </array>

  <key>RunAtLoad</key>
  <true/>

  <key>KeepAlive</key>
  <true/>

  <key>StandardOutPath</key>
  <string>/tmp/sshfs-keeper.log</string>

  <key>StandardErrorPath</key>
  <string>/tmp/sshfs-keeper.log</string>

  <!-- Wait for network before starting -->
  <key>NetworkState</key>
  <true/>
</dict>
</plist>
